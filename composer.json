{
    "name": "oryx/orm",
    "description": "DQL-centric ORM for PHP 8.0+ with Symfony-inspired scout querying & oryx/mvc-adr integration",
    "type": "library",
    "require": {
        "php": "^8.2",
        "doctrine/dbal": "^3.0",
        "doctrine/orm": "^2.14",
        "doctrine/migrations": "^3.5",
        "doctrine/annotations": "^2.0",
        "league/config": "^1.2",
        "league/event": "^2.2",
        "league/factory-muffin": "^3.3",
        "league/flysystem": "^3.0",
        "league/fractal": "^0.19",
        "league/pipeline": "^1.0",
        "league/tactician": "^2.0",
        "league/uri": "^6.0",
        "symfony/dotenv": "^6.4",
        "league/climate": "^3.10",
        "doctrine/instantiator": "^1.5",
        "nette/utils": "^4.0",
        "symfony/console": "^6.0",
        "symfony/string": "^6.0",
        "symfony/event-dispatcher": "^6.0",
        "symfony/filesystem": "^6.0",
        "symfony/finder": "^6.0",
        "symfony/options-resolver": "^6.0",
        "symfony/process": "^6.0",
        "symfony/stopwatch": "^6.0",
        "webmozart/assert": "^1.0",
        "oryx/mvc": "dev-develop",
        "oryx/adr": "dev-develop"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "mockery/mockery": "^1.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^0.12"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/pbrilius/mvc"
        },
        {
            "type": "vcs",
            "url": "https://github.com/pbrilius/adr"
        }
    ],
    "autoload": {
        "psr-4": {
            "Oryx\\ORM\\": "src/",
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Oryx\\ORM\\Tests\\": "tests/",
            "App\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/console"
    ],
    "scripts": {
        "cs-check": "php-cs-fixer fix --dry-run --diff --allow-unsupported-php-version=no",
        "cs-fix": "php-cs-fixer fix --allow-unsupported-php-version=no",
        "stan": "phpstan analyse src tests",
        "test": "phpunit"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}