{
  "name": "oryx/orm",
  "description": "DQL-centric ORM for PHP 8.0+ with Symfony-inspired scout querying & oryx/mvc-adr integration",
  "type": "library",
  "require": {
    "php": "^8.0",
    "doctrine/dbal": "^3.0",
    "doctrine/orm": "^2.14",
    "league/config": "^1.2",
    "league/event": "^2.2",
    "league/factory-muffin": "^3.3",
    "league/flysystem": "^3.0",
    "league/fractal": "^0.19",
    "league/pipeline": "^1.0",
    "league/tactician": "^2.0",
    "league/uri": "^7.0",
    "symfony/dotenv": "^6.0",
    "league/climate": "^3.10",
    "doctrine/instantiator": "^2.0",
    "nette/utils": "^4.0",
    "symfony/console": "^6.4",
    "symfony/string": "^6.4",
    "symfony/event-dispatcher": "^6.4",
    "symfony/filesystem": "^6.4",
    "symfony/finder": "^6.4",
    "symfony/options-resolver": "^6.4",
    "symfony/process": "^6.4",
    "symfony/stopwatch": "^6.4",
    "webmozart/assert": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "mockery/mockery": "^1.0",
    "friendsofphp/php-cs-fixer": "^3.0",
    "phpstan/phpstan": "^1.10",
    "vimeo/psalm": "^6.0"
  },
  "autoload": {
    "psr-4": {
      "Oryx\\ORM\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Oryx\\ORM\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "cs-check": "php-cs-fixer fix --dry-run --diff",
    "cs-fix": "php-cs-fixer fix",
    "stan": "phpstan analyse",
    "psalm": "psalm",
    "test": "phpunit"
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}